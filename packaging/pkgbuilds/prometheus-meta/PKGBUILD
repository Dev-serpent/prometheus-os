# Maintainer: Prometheus OS Team <dev@prometheus-os.dev>
pkgname=prometheus-meta
pkgver=0.1.0
pkgrel=1
pkgdesc="Prometheus OS - AI-First Operating System (meta-package)"
arch=('x86_64')
url="https://prometheus-os.dev"
license=('GPL3')
groups=('prometheus-os')
depends=(
    'linux-zen' 'linux-firmware' 'intel-ucode' 'amd-ucode'
    'mesa' 'mesa-utils' 'vulkan-icd-loader' 'vulkan-intel' 'vulkan-radeon'
    'nvidia-dkms' 'libva' 'libva-intel-driver' 'libva-mesa-driver'
    'pipewire' 'pipewire-alsa' 'pipewire-pulse' 'wireplumber'
    'wlroots' 'wayland' 'wayland-protocols' 'libxkbcommon' 'libinput'
    'systemd' 'plymouth' 'btrfs-progs' 'snapper' 'snap-pac'
    'sbctl' 'apparmor' 'bubblewrap'
    'flatpak' 'python' 'nodejs' 'rust' 'cargo'
    'base-devel' 'git' 'cmake' 'clang'
    'inter-font' 'noto-fonts' 'noto-fonts-emoji' 'ttf-jetbrains-mono'
    'networkmanager' 'iwd' 'bluez' 'bluez-utils'
    'pacman-contrib' 'reflector' 'fwupd'
)
optdepends=(
    'gnome: GNOME desktop environment integration'
    'flatpak: containerized application support'
    'docker: container development'
    'steam: gaming'
)
install=prometheus.install
source=("$pkgname-$pkgver.tar.gz::https://github.com/sudorootvector/prometheus-os/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "$srcdir/prometheus-os-$pkgver"

    mkdir -p "$pkgdir/usr/share/doc/prometheus"
    mkdir -p "$pkgdir/etc/prometheus"

    cat > "$pkgdir/etc/os-release" << 'EOF'
NAME="Prometheus OS"
ID=prometheus
PRETTY_NAME="Prometheus OS 0.1 (Prometheus)"
VERSION_ID="0.1"
VERSION_CODENAME=prometheus
ID_LIKE=arch
HOME_URL="https://prometheus-os.dev"
LOGO=prometheus
EOF

    mkdir -p "$pkgdir/etc/systemd/system/gdm.service.d"
    cat > "$pkgdir/etc/systemd/system/gdm.service.d/10-prometheus-session.conf" << 'EOF'
[Service]
Environment=XDG_SESSION_TYPE=wayland
Environment=GDK_BACKEND=wayland
EOF

    mkdir -p "$pkgdir/etc/dconf/db/gdm.d"
    cat > "$pkgdir/etc/dconf/db/gdm.d/00-prometheus" << 'DCONF'
[org/gnome/desktop/interface]
gtk-theme='Prometheus-Dark'
icon-theme='Prometheus-Icons'
font-name='Inter 10'
color-scheme='prefer-dark'
[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/prometheus/default.png'
[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/prometheus/lock.png'
DCONF

    mkdir -p "$pkgdir/etc/skel/.config"
    mkdir -p "$pkgdir/etc/skel/.local/share/gnome-shell"
    echo "prometheus-ai@prometheus-os.dev,prometheus-dashboard@prometheus-os.dev,prometheus-layout@prometheus-os.dev" \
        > "$pkgdir/etc/skel/.local/share/gnome-shell/enabled-extensions"
    cat > "$pkgdir/etc/skel/.config/prometheus.conf" << 'CONF'
[desktop]
preferred_environment = "gnome"
autostart_ai = true
theme = "prometheus-dark"
CONF

    install -Dm644 "$srcdir/../../resources/brand/logo.svg" "$pkgdir/usr/share/pixmaps/prometheus.svg"
    install -Dm644 "$srcdir/../../resources/wallpapers/default.png" "$pkgdir/usr/share/backgrounds/prometheus/default.png" 2>/dev/null || true
    install -Dm644 "$srcdir/../../resources/wallpapers/lock.png" "$pkgdir/usr/share/backgrounds/prometheus/lock.png" 2>/dev/null || true
}
